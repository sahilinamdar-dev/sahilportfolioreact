# Brevo — SERVER-SIDE only (used by /api/contact.js). No VITE_ prefix = never shipped to browser.
# Set these in Vercel -> Settings -> Environment Variables (and in .env for local `vercel dev`).
BREVO_API_KEY=your_brevo_api_key_here

# A sender email VERIFIED in your Brevo account (Senders & IPs)
BREVO_SENDER_EMAIL=inamdarsahil708@gmail.com

# Where contact-form messages are delivered (your inbox)
CONTACT_TO_EMAIL=sahilinamdar212@gmail.com
